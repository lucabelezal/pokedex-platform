#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
SUBJECT="$(head -n 1 "$MSG_FILE")"

# Permite merge commit automatico
if [[ "$SUBJECT" =~ ^Merge\  ]]; then
  exit 0
fi

# Padrao Conventional Commits:
# tipo(escopo-opcional)!: descricao
PATTERN='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9._/-]+\))?!?: .{1,}$'

if ! [[ "$SUBJECT" =~ $PATTERN ]]; then
  cat <<'EOF'
Mensagem de commit invalida.
Use: tipo(escopo-opcional): descricao em portugues

Exemplos validos:
  feat(favoritos): bloquear remocao sem autenticacao
  fix(bff): corrigir validacao de token jwt
  docs(readme): atualizar fluxo de execucao local
EOF
  exit 1
fi
